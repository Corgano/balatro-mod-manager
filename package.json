{
  "name": "balatro-mod-manager",
  "version": "0.4.1",
  "description": "A mod manager for Balatro - easily install and manage mods for the popular roguelike deckbuilding game",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "oxlint -c oxlint.json",
    "lint:fix": "oxlint -c oxlint.json --fix",
    "format": "prettier --write \"src/**/*.{svelte,ts,js,css,html}\"",
    "tauri": "tauri",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "license": "GPL-3.0",
  "dependencies": {
    "@tauri-apps/api": "^2.9.1",
    "@tauri-apps/plugin-dialog": "^2.6.0",
    "@tauri-apps/plugin-fs": "^2.4.5",
    "@tauri-apps/plugin-os": "~2.3.2",
    "@tauri-apps/plugin-shell": "^2.3.4",
    "@tauri-apps/plugin-window-state": "^2.4.1",
    "@types/flexsearch": "^0.7.42",
    "flexsearch": "^0.8.212"
  },
  "devDependencies": {
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.50.1",
    "@sveltejs/vite-plugin-svelte": "^5.1.1",
    "@tauri-apps/cli": "^2.9.6",
    "@testing-library/svelte": "^5.3.1",
    "@vitest/coverage-v8": "^4.0.18",
    "happy-dom": "^20.3.9",
    "lucide-svelte": "^0.483.0",
    "marked": "^17.0.1",
    "oxlint": "^1.42.0",
    "prettier": "^3.8.1",
    "prettier-plugin-svelte": "^3.4.1",
    "svelte": "^5.48.4",
    "svelte-check": "^4.3.5",
    "svelte-confetti": "^2.3.2",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3",
    "vite": "^6.4.1",
    "vitest": "^4.0.18"
  },
  "packageManager": "bun@1.2.5"
}

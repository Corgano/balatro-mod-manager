{
  "$schema": "https://raw.githubusercontent.com/jetify-com/devbox/0.16.0/.schema/devbox.schema.json",
  "packages": [
    "rustc",
    "cargo",
    "pkg-config",
    "glib",
    "gtk3",
    "libsoup_3",
    "webkitgtk_4_1",
    "cairo",
    "pango",
    "atk",
    "openssl",
    "librsvg",
    "bash",
    "curl",
    "bun@latest"
  ],
  "shell": {
    "init_hook": [
      "export PKG_CONFIG_PATH=$PKG_CONFIG_PATH:/usr/lib/x86_64-linux-gnu/pkgconfig"
    ]
  }
}
